//@version=6
indicator(title="Clean RSI Zones Enhanced", shorttitle="RSI Zones+", format=format.price, precision=2)

// === Inputs ===
rsiLength = input.int(14, minval=1, title="RSI Length")
rsiSource = input.source(close, "Source")
obLevel = input.int(70, "Overbought Level", minval=50, maxval=95, step=5)
osLevel = input.int(30, "Oversold Level", minval=5, maxval=50, step=5)

// === RSI Calculation ===
change = ta.change(rsiSource)
up = ta.rma(math.max(change, 0), rsiLength)
down = ta.rma(-math.min(change, 0), rsiLength)
rsi = down == 0 ? 100 : up == 0 ? 0 : 100 - (100 / (1 + up / down))

// === Plot RSI with Dynamic Color ===
rsiColor = if rsi > obLevel
    color.red
else if rsi < osLevel
    color.green
else
    color.rgb(107, 73, 231)

plot(rsi, title="RSI", color=color.new(rsiColor, 0), linewidth=2)

// === Horizontal Levels ===
obLine = hline(obLevel, "Overbought", color=color.red, linestyle=hline.style_dashed)
midLine = hline(50, "Middle", color=color.gray, linestyle=hline.style_dotted)
osLine = hline(osLevel, "Oversold", color=color.green, linestyle=hline.style_dashed)

// === Background Highlighting (Horizontal Zones based on RSI values) ===
fill(hline(100, display=display.none), hline(obLevel, display=display.none), color=color.new(color.red, 90), title="Overbought Zone")
fill(hline(obLevel, display=display.none), hline(osLevel, display=display.none), color=color.new(color.white, 90), title="Neutral Zone")
fill(hline(osLevel, display=display.none), hline(0, display=display.none), color=color.new(color.green, 90), title="Oversold Zone")



// === SMA Line (Optional) ===
smaLength = input.int(14, title="RSI MA Length")
showSMA = input.bool(true, title="Show RSI SMA")

rsiSMA = ta.sma(rsi, smaLength)
plot(showSMA ? rsiSMA : na, title="RSI SMA", color=color.orange, linewidth=1)